# ===== 数据库 =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=trade_analyze
# 连接池
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_ECHO=false

# ===== 数据源 =====
# akshare 无需 token；切换 tushare 时填入
TUSHARE_TOKEN=

# ===== 选股参数版本 =====
# 当前生效的参数配置版本号（对应 param_config 表）
ACTIVE_PARAM_VERSION=v1

# ===== 跑批 =====
# 首次全量拉取的历史起始日期
HISTORY_START_DATE=2023-01-01
# 数据采集并发与限流（akshare 免费源需控速）
FETCH_MAX_WORKERS=4
FETCH_SLEEP_SECONDS=0.2

# ===== API =====
API_HOST=0.0.0.0
API_PORT=8000
# 前端跨域允许的来源，逗号分隔；* 表示全部
API_CORS_ORIGINS=*

# ===== 日志 =====
LOG_LEVEL=INFO
LOG_DIR=logs
